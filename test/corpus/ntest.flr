Main = {
    use Math.factorial
        
    extern println: str -> unit
 
    type Functor = {
        fmap: Self -> (?A -> ?B) -> Functor[?B]
    }
    
    type Option[?T] = |Some ?T, None|

    extend Option[?T] :: Functor = {
        map o f : Option[?T] -> (?T -> ?U) -> Option[?U] =
            match o 
               as | Some x| then |Some (f x)|
               as | None | then  |None|
            
    }
    
    x: num = 3
       
    main: num = 
        let a = Some 2 in
        let b = Some 3 in
        a :: fmap (fn x => x * 2)
            +
        b :Functor: fmap (fn x => x * 3)
}            
