==================
Complicated example
==================


Main = {
	use Sys

	Fallible[?T] = type {
		extract: self -> Option[?T]
    }
    
    extend Fallible[?T] = {
        unwrap: self -> ?T = fn i =>
		    match i :: extract 
			    as | Some x | then x
		        as | None   | then Sys.panic "unwrap failed"
			end

	    unwrap_or: self -> ?T -> ?T = fn i alternative =>
		    match i :: extract
			    as | Some x | then x
		        as | None   | then alternative
			end

	    expect: self -> str -> ?T = fn i alternative =>
		    match i :: extract
		        as | Some x | then x
		        as | None   | then Sys.panic msg
			end
    }
    
	pub Point = type {
		x : num
	    y : num
	}

	Option[?T] = type | Some ?T, None |

    extend Option[?T] :: Fallible[?T] = {
		extract self = self
	}

	Result[?T, ?E] = type | Ok ?T, Err ?E |

	extend Result[?T, ?E] :: Fallible[?T] = {
	    extract self =
			match self
				as | Ok x  | then Some x
		        as | Err _ | then None
			end
	}
  
	safe_slope: Point -> Point -> Option[num] = fn p1 p2 => {
        denominator = p2.x - p1.x
		return match denominator 
        	as 0 then None 
        	as _ then {
				numerator = p2.y - p1.x
				return numerator / denominator
			}
			end
    }
  
	main: num = {
		p1 = {x = 3, y = 4}
		p2 = {x = 3, y = 6}
		random = {data = p2, extra = unit}
        return (safe_slope p1 random.data) :: unwrap_or 3
    } 
 }
