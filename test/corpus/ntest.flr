==================
Complicated example
==================
Main = {
	use Sys

	type Fallible[?T] = {
		extract : self -> Option[?T]
	}

    extend Fallible[?T] = {
        unwrap i : self -> ?T =
		    match i :: extract 
			    as | Some x | then x
		        as | None   | then Sys.panic "unwrap failed"
			end

	    unwrap_or i alternative : self -> ?T -> ?T =
		    match i :: extract
			    as | Some x | then x
		        as | None    | then alternative
			end

	    expect i msg : self -> str -> ?T =
		    match i :: extract
		        as | Some x | then x
		        as | None   | then Sys.panic msg
			end
    }

	type Point = {
		x : num
	    y : num
	}

	type Option[?T] = | Some ?T, None |

    extend Option[?T] :: Fallible[?T] = {
		extract self = self
	}

	type Result[?T, ?E] = | Ok ?T, Err ?E |

	extend Result[?T, ?E] :: Fallible[?T] = {
	    extract self =
			match self
				as | Ok x  | then Some x
		        as | Err _ | then None
			end 
				
	}
  
	safe_slope p1 p2: Point -> Point -> Option[num] = 
        let denominator = p2.x - p1.x in
		if denominator == 0 then None else
		let numerator = p2.y - p1.x in 
		numerator / denominator
    
  
	main: num = 
		let p1 = {x = 3, y = 4} in
		let p2 = {x = 3, y = 6} in
		let random = {data = p2, extra = unit} in
		(safe_slope p1 random.data) :: unwrap_or 3
}

