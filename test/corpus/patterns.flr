===
pattern tests
===

Test = {
    use PointXY
    use Option

    product_expansion: PointXY = {
        point = PointXY :: new {x = 3, y = 4}
        {a @ x, b @ y} = point
        new_point = PointXY :: new { x = a, b = y}
        return new_point
    }
    matching = {
        opt = Option :: Some product_expansion 
        return match opt
          as |Some { a @ x, b @ y}| then
            a
          as |None| then 0
        end
    }
}        

---
