===
pattern tests
===

Test = {
    use PointXY
    use Option

    product_expansion: PointXY =
        let point = PointXY :: new {x = 3, y = 4} in
        let {a @ x, b @ y} = point in
        let new_point = PointXY :: new { x = a, b = y}in
        new_point

    matching =
        let opt = Option :: Some product_expansion in
        match opt
          as |Some { a @ x, b @ y}| then
            a
          as |None| then 0
        end
}        

